# Copy this file to .env.local and fill in the values below.
# .env.local is gitignored — never commit real credentials.

# Sanity project ID. Found at sanity.io/manage on the project's dashboard.
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name. Defaults to "production" for new projects.
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API read token. Required only for previewing draft/unpublished content
# and for server-side reads that bypass the public CDN.
# Generate at sanity.io/manage → API → Tokens → "Add API token" with Viewer permission.
# Server-only — do NOT add a NEXT_PUBLIC_ prefix.
SANITY_API_READ_TOKEN=
