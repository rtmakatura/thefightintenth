# Copy this file to .env.local and fill in the values below.
# .env.local is gitignored — never commit real credentials.

# ─── Sanity ────────────────────────────────────────────────────────────────

# Sanity project ID. Found at sanity.io/manage on the project's dashboard.
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name. Defaults to "production" for new projects.
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API read token. Required only for previewing draft/unpublished content
# and for server-side reads that bypass the public CDN.
# Generate at sanity.io/manage → API → Tokens → "Add API token" with Viewer permission.
# Server-only — do NOT add a NEXT_PUBLIC_ prefix.
SANITY_API_READ_TOKEN=

# Sanity API write token. Required only for one-shot migration scripts.
# Generate at sanity.io/manage → API → Tokens → "Add API token" with Editor permission.
# Server-only — do NOT add a NEXT_PUBLIC_ prefix.
SANITY_API_WRITE_TOKEN=

# ─── Resend (contact form) ─────────────────────────────────────────────────

# Resend API key — required for contact form submissions.
# 1. Sign up at https://resend.com (free tier: 100 emails/day, 3,000/mo)
# 2. Create an API key in the dashboard
# 3. Copy it here as RESEND_API_KEY
#
# Until a custom domain is verified in Resend, the app sends from
# `onboarding@resend.dev`. With the free tier and that sender, Resend
# will only deliver to the email address used to register the Resend
# account — sign up using makaturaorlando@gmail.com so the form works
# out of the box. Once a domain is verified, set CONTACT_FROM below.
RESEND_API_KEY=

# Optional: override the From: header once a domain is verified in Resend.
# Example: CONTACT_FROM="The Fightin' Tenth <noreply@thefightintenth.com>"
# CONTACT_FROM=

# Optional: override the To: header (default is AUTHOR_EMAIL from lib/content.ts).
# CONTACT_TO=
